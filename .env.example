# =============================================================================
# Masters Pool — Environment Variables
# Copy this file to .env.local and fill in every value before running locally
# or deploying to Vercel.
# =============================================================================

# --- Supabase (required) -----------------------------------------------------
# Find in: Supabase Dashboard → Project Settings → API

# Your project's REST/Auth URL  (starts with https://<ref>.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Anonymous (public) key — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — SERVER SIDE ONLY. Never expose in client code.
# Used by: /api/sync-scores, /api/admin/stats, /api/admin/sync, admin/actions.ts
SUPABASE_SERVICE_ROLE_KEY=

# --- Cron auth (required) ----------------------------------------------------
# Protects POST /api/sync-scores from unauthorized callers.
# Vercel Cron sends this as "Authorization: Bearer <CRON_SECRET>".
# Generate with:  openssl rand -hex 32
# Must match the value in Vercel → Project Settings → Environment Variables.
CRON_SECRET=

# --- Admin page (required) ---------------------------------------------------
# Password for the /admin dashboard (login form).
# Used by: admin/actions.ts, /api/admin/stats, /api/admin/sync
# Set any strong password (e.g. openssl rand -hex 16).
ADMIN_PASSWORD=
